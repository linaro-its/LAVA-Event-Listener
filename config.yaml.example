# LAVA Event Listener Configuration

lava_servers:
  - name: "lab-1"
    url: "https://lava.example.com/"
    # Optional: credentials for authenticated websocket access and REST API calls.
    # The token is reused for both; it must belong to a user with permission to submit jobs.
    # username: "bot-user"
    # token: "your-lava-token"
    # Optional: automatically trigger a healthcheck job when a DUT failure is detected.
    # Requires 'token' to be set. Omit or set enabled: false to disable.
    # healthcheck:
    #   enabled: true
    #   poll_interval_seconds: 30   # how often to check job status (default: 30)
    #   timeout_minutes: 30         # give up polling after this many minutes (default: 30)
    # Optional: Jira accounts to add as "Request participants" on newly created tickets.
    # participants:
    #   - user@example.com
    #   - another@example.com

  - name: "lab-2"
    url: "https://lava2.example.com/"

jira:
  url: "https://yourorg.atlassian.net"
  email: "bot@example.com"
  api_token: "your-jira-api-token"
  project_key: "LAVAOPS"
  # The JSM request type name (as shown in your project's request types settings)
  request_type: "Service Request"

# Path to the JSON file that tracks device-to-ticket mappings.
# The directory must exist and be writable by the service user.
state_file: "/var/lib/lava-event-listener/state.json"

# Logging level: DEBUG, INFO, WARNING, ERROR
log_level: "INFO"

# Optional: Sentry error tracking. Remove or leave empty to disable.
sentry:
  dsn: "https://examplePublicKey@o0.ingest.sentry.io/0"

# Optional: BetterStack heartbeat monitoring. Remove or leave empty to disable.
# The heartbeat is only sent when at least one LAVA websocket connection is active.
betterstack:
  heartbeat_url: "https://uptime.betterstack.com/api/v1/heartbeat/your-heartbeat-id"
  interval_seconds: 60

# Optional: SPIRE integration for LAA-connected devices (Tier 3).
# When configured, the listener will automatically create/delete SPIRE DUT resources
# in response to device Unknown/Retired health transitions on LAA devices.
# Both production and staging credentials are required because a single LAVA server
# may host devices belonging to subscriptions in either environment.
# spire:
#   cache_dir: "/var/lib/lava-event-listener"   # directory for biscuit token caches
#   production:
#     auth0_domain: "linaro-production.auth0.com"
#     auth0_client_id: "your-prod-m2m-client-id"
#     auth0_client_secret: "your-prod-m2m-client-secret"
#     auth0_audience: "https://spire-api.linaro.org"
#     spire_api_base: "https://spire-api.linaro.org/rest/v1"
#     lms_base: "https://lms-api.linaro.org/rest/v1"
#   staging:
#     auth0_domain: "linaro-staging.auth0.com"
#     auth0_client_id: "your-staging-m2m-client-id"
#     auth0_client_secret: "your-staging-m2m-client-secret"
#     auth0_audience: "https://spire-api-staging.linaro.org"
#     spire_api_base: "https://spire-api-staging.linaro.org/rest/v1"
#     lms_base: "https://lms-api-staging.linaro.org/rest/v1"

# Optional: Slack alerting for SPIRE sync failures.
# Posts to a Slack incoming webhook when SPIRE operations fail after retries.
# slack:
#   webhook_url: "your-slack-incoming-webhook-url"
#   alert_rate_limit_seconds: 600           # minimum seconds between alerts per device (default: 600)
#   alert_on_unresolved_subscription: true  # notify when subscription can't be resolved (default: true)
